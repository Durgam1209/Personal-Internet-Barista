# personal.cafe Environment Variables

# Anthropic Claude API Key (if calling Anthropic directly)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenRouter API Key (Alternative to direct Anthropic, useful for hackathons)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Supabase Configuration
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key-here
